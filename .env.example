# ─────────────────────────────────────────────────────────────────
# IJEAF Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# NE JAMAIS committer le fichier .env
# ─────────────────────────────────────────────────────────────────

# Base de données
DB_URL=jdbc:postgresql://localhost:5432/ijeaf_dev
DB_USERNAME=ijeaf
DB_PASSWORD=ijeaf_dev_password

# JWT — générer avec : openssl rand -base64 64
JWT_SECRET=change_me_generate_a_strong_secret_of_at_least_256_bits
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# OAuth2
GOOGLE_CLIENT_ID=change_me
GOOGLE_CLIENT_SECRET=change_me
APPLE_CLIENT_ID=change_me

# Firebase FCM
FIREBASE_CREDENTIALS_PATH=src/main/resources/firebase-credentials.json

# Stockage images S3
AWS_ACCESS_KEY=change_me
AWS_SECRET_KEY=change_me
AWS_BUCKET_NAME=ijeaf-images
AWS_REGION=eu-west-1

# Fedapay
FEDAPAY_API_KEY=change_me
FEDAPAY_WEBHOOK_SECRET=change_me
FEDAPAY_SANDBOX=true

# AfrikSMS
AFRIKSMS_API_KEY=change_me
AFRIKSMS_SENDER_ID=IJEAF

# Email SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=change_me@gmail.com
MAIL_PASSWORD=change_me

# App
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:postgresql://localhost:5432/ijeaf_dev
DB_USERNAME=ijeaf
DB_PASSWORD=ijeaf_dev_password
JWT_SECRET=your_super_secret_key_min_256_bits_here
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
FEDAPAY_API_KEY=
FIREBASE_CREDENTIALS_PATH=src/main/resources/firebase-credentials.json
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=
AFRIKSMS_API_KEY=
MAIL_USERNAME=
MAIL_PASSWORD=